{
  "manifest_version": 3,
  "name": "Lore Web Capture",
  "version": "1.0",
  "description": "Captures pages you actively read into your Lore knowledge base",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}